DEEPSEEK_API_KEY=your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# deepseek-chat 别名将于 2026-07-24 弃用
DEEPSEEK_MODEL=deepseek-v4-flash
DUCKDB_PATH=data/chainpilot.duckdb

# 邮件半自动接入；HOST/PORT/USER/PASSWORD 齐全时使用 IMAP，否则使用 data/inbox/
INGEST_MAIL_HOST=
INGEST_MAIL_PORT=993
INGEST_MAIL_USER=
INGEST_MAIL_PASSWORD=
INGEST_MAIL_FOLDER=INBOX
# 逗号分隔；空值会安全地拦截全部发件人
INGEST_MAIL_ALLOWED_SENDERS=
# 缺省、0 或非法值均关闭后台轮询
INGEST_MAIL_POLL_SECONDS=0
